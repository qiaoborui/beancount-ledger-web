{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": false,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "types": ["vite/client", "node"],
    "paths": { "@/*": ["./src/*"] }
  },
  "include": [
    "vite.config.ts",
    "src/main.tsx",
    "src/components/**/*.ts",
    "src/components/**/*.tsx",
    "src/lib/browserRouter.ts",
    "src/lib/clientFetch.ts",
    "src/lib/indexedLedgerCache.ts",
    "src/lib/money.ts",
    "src/lib/schemas.ts",
    "src/lib/timeRange.ts",
    "src/app/globals.css"
  ],
  "exclude": ["node_modules"]
}
