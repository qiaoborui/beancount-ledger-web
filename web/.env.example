# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Single-user login password. Use a long random password for public deployment.
APP_PASSWORD=

# Public browser URL for passkeys and same-origin checks when served behind a proxy.
PUBLIC_ORIGIN=https://ledger.example.com
# Optional list for passkeys across related origins. Separate entries with spaces, commas, tabs, or newlines.
WEBAUTHN_PUBLIC_ORIGIN=https://ledger.example.com, https://finance.example.com
WEBAUTHN_RP_ID=ledger.example.com
# Optional: allow a separately hosted frontend to call this backend with cookies.
LEDGER_CORS_ORIGINS=https://ledger.example.com

# Disable login and sensitive-data unlock. Only use for preview environments.
LEDGER_AUTH_DISABLED=false

# Stateless ledger-web writes go through the GitHub API; reads come from the
# Postgres ledger read model. Do not set LEDGER_ROOT, RUNTIME_DIR, or
# BEAN_CHECK_BIN on the API service.
LEDGER_GIT_BRANCH=main
LEDGER_GITHUB_OWNER=
LEDGER_GITHUB_REPO=
LEDGER_GITHUB_TOKEN=
LEDGER_GITHUB_API_URL=

# Postgres for the read model, runtime state, locks, and uploaded import preview files.
DATABASE_URL=

# AI parser. Defaults to DeepSeek JSON mode.
LEDGER_AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional: set LEDGER_AI_PROVIDER=openai to use OpenAI structured outputs.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4.1-mini

# Web Push notifications. Generate VAPID keys with:
# pnpm dlx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:you@example.com

# Gmail automatic bill import. See docs/gmail-import-automation.md.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URL=https://ledger.example.com/api/integrations/gmail/callback
GMAIL_PUBSUB_TOPIC=projects/PROJECT_ID/topics/ledger-gmail
GMAIL_PUBSUB_AUDIENCE=https://ledger.example.com/api/integrations/gmail/pubsub
GMAIL_PUBSUB_SERVICE_ACCOUNT=gmail-push@PROJECT_ID.iam.gserviceaccount.com
GMAIL_LABEL=Ledger/Bills
GMAIL_ALLOWED_SENDERS=bill@example-bank.com,statement@example-card.com
GMAIL_TOKEN_ENCRYPTION_KEY=
GMAIL_SYNC_LOOKBACK_DAYS=30
GMAIL_ZIP_PASSWORDS=
GMAIL_ZIP_TIMEOUT_SECONDS=20
CRON_SECRET=

# Optional Git commit author for GitHub API writes.
LEDGER_GIT_AUTHOR_NAME=
LEDGER_GIT_AUTHOR_EMAIL=

# Indexer only. The worker validates an existing local checkout or mounted ledger
# directory and indexes it into Postgres; schedule it with cron, systemd timer,
# GitHub Actions, or your container platform.
# LEDGER_ROOT=/path/to/private-ledger
# LEDGER_GIT_BRANCH=main
# BEAN_CHECK_BIN=
