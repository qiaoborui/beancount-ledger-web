# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Single-user login password. Use a long random password for public deployment.
APP_PASSWORD=

# AI parser. Defaults to DeepSeek JSON mode.
LEDGER_AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional: set LEDGER_AI_PROVIDER=openai to use OpenAI structured outputs.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4.1-mini

# Web Push notifications. Generate VAPID keys with:
# npx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC_KEY=
NEXT_PUBLIC_WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:you@example.com
# AI chat completion Web Push is sent whenever the page went to the background during the request.

# Ledger repository path. Defaults to ../examples/minimal-ledger for local development.
# In production, point this to your private Beancount ledger repository.
LEDGER_ROOT=../examples/minimal-ledger

# Runtime state directory for passkeys, web push subscriptions, notifications, locks.
# Defaults to $LEDGER_ROOT/.runtime. Use a separate directory in production if preferred.
RUNTIME_DIR=

# Optional. Useful when Next/Vercel/local service PATH cannot find bean-check.
BEAN_CHECK_BIN=

# Optional Fava integration. Keep Fava bound to localhost/private network;
# the app proxies it through authenticated /api/fava routes.
FAVA_ENABLED=false
FAVA_INTERNAL_URL=http://127.0.0.1:5000

# Git scheduler. Set LEDGER_GIT_SCHEDULER=false to disable.
LEDGER_GIT_SCHEDULER=true
LEDGER_GIT_PULL_INTERVAL_MINUTES=15
LEDGER_GIT_COMMIT_INTERVAL_MINUTES=60
