# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Single-user login password. Use a long random password for public deployment.
APP_PASSWORD=

# Public browser URL for passkeys and same-origin checks when served behind a proxy.
PUBLIC_ORIGIN=https://ledger.example.com
# Optional list for passkeys across related origins. Separate entries with spaces, commas, tabs, or newlines.
WEBAUTHN_PUBLIC_ORIGIN=https://ledger.example.com, https://finance.example.com
WEBAUTHN_RP_ID=ledger.example.com
# Optional: allow a separately hosted frontend to call this backend with cookies.
LEDGER_CORS_ORIGINS=https://ledger.example.com

# Disable login and sensitive-data unlock. Only use for preview environments.
LEDGER_AUTH_DISABLED=false

# Vercel API production ledger storage. Writes go through the GitHub API; reads
# come from the Postgres ledger read model. Do not set LEDGER_GIT_REMOTE,
# LEDGER_GIT_WORKDIR, LEDGER_ROOT, or BEAN_CHECK_BIN on the Vercel API service.
LEDGER_STORAGE=github_api
LEDGER_GIT_BRANCH=main
LEDGER_GITHUB_OWNER=
LEDGER_GITHUB_REPO=
LEDGER_GITHUB_TOKEN=
LEDGER_GITHUB_API_URL=
LEDGER_READ_MODEL=postgres
LEDGER_READ_MODEL_STRICT=true

# Postgres for the read model, runtime state, locks, and uploaded import preview files.
DATABASE_URL=

# AI parser. Defaults to DeepSeek JSON mode.
LEDGER_AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

# Optional: set LEDGER_AI_PROVIDER=openai to use OpenAI structured outputs.
OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4.1-mini

# Web Push notifications. Generate VAPID keys with:
# pnpm dlx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:you@example.com

# Optional Git commit author for GitHub API or worker-created commits.
LEDGER_GIT_AUTHOR_NAME=
LEDGER_GIT_AUTHOR_EMAIL=

# Local worker or self-hosted mode only. The worker validates an existing local
# checkout or mounted ledger directory and indexes it into Postgres; keep these
# off Vercel API hosts.
# LEDGER_STORAGE=filesystem
# LEDGER_ROOT=/path/to/private-ledger
# LEDGER_GIT_BRANCH=main
# RUNTIME_DIR=
# BEAN_CHECK_BIN=
# LEDGER_INDEX_INTERVAL_SECONDS=300
