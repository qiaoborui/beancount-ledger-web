# Pi ledger agent runtime example.
#
# This file is intentionally not loaded by the Go server. Use it for the Pi
# process or sidecar that hosts the ledger assistant.

# Point Pi at the repo-local agent/policy directory if your Pi install supports
# PI_CODING_AGENT_DIR. Otherwise copy .pi/agent/* into your normal Pi agent dir.
PI_CODING_AGENT_DIR=.pi/agent

# Provider credentials belong to the Pi runtime, not the browser.
# Use the variables expected by your Pi provider/plugin.
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
DEEPSEEK_API_KEY=

# Choose the model either with Pi's normal /model command or by adding a static
# model field to .pi/agent/agents/ledger-assistant.md.
# Example frontmatter values depend on your Pi provider/plugin naming:
# model: openai/gpt-5.4-mini
# model: openai-codex/gpt-5.3-codex-spark
# thinking: low
LEDGER_PI_PROVIDER=deepseek
LEDGER_PI_MODEL=deepseek-v4-flash
LEDGER_PI_THINKING=low

# Ledger MCP bridge. This token must match LEDGER_AGENT_TOOL_TOKEN in the Go
# service environment. Generate with: openssl rand -base64 32
LEDGER_AGENT_TOOL_BASE_URL=http://127.0.0.1:3000
LEDGER_AGENT_TOOL_TOKEN=
