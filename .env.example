# Beancount Ledger Web — Vercel API production configuration

# Ledger writes: use the GitHub API directly. Do not set LEDGER_STORAGE,
# LEDGER_READ_MODEL, LEDGER_ROOT, RUNTIME_DIR, or BEAN_CHECK_BIN on the API service.
LEDGER_GIT_BRANCH=main
# Optional for multi-backend groups; GitHub owner/repo/branch provides the default.
LEDGER_CLUSTER_ID=
LEDGER_GITHUB_OWNER=OWNER
LEDGER_GITHUB_REPO=private-ledger
LEDGER_GITHUB_TOKEN=
LEDGER_GITHUB_API_URL=

# Supabase Postgres for the read model, runtime state, locks, rate limits,
# notifications, push subscriptions, and import preview blobs.
DATABASE_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
POSTGRES_MAX_OPEN_CONNS=2
POSTGRES_MAX_IDLE_CONNS=1
POSTGRES_CONN_MAX_IDLE_SECONDS=60

# Required secrets.
AUTH_SECRET=
APP_PASSWORD=

# Public browser URL for passkeys.
PUBLIC_ORIGIN=https://ledger.example.com
WEBAUTHN_RP_ID=ledger.example.com
# Optional: allow a separately hosted frontend to call this backend with cookies.
# Separate entries with spaces, commas, tabs, or newlines.
LEDGER_CORS_ORIGINS=https://ledger.example.com

# AI provider.
LEDGER_AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4.1-mini

# Web Push notifications.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:you@example.com

# Gmail automatic bill import. Use a personal Google Cloud project and create
# the Ledger/Bills label plus sender filters before connecting from /import.
GMAIL_CLIENT_ID=
GMAIL_CLIENT_SECRET=
GMAIL_OAUTH_REDIRECT_URL=https://ledger.example.com/api/integrations/gmail/callback
GMAIL_PUBSUB_TOPIC=projects/PROJECT_ID/topics/ledger-gmail
GMAIL_PUBSUB_AUDIENCE=https://ledger.example.com/api/integrations/gmail/pubsub
GMAIL_PUBSUB_SERVICE_ACCOUNT=gmail-push@PROJECT_ID.iam.gserviceaccount.com
GMAIL_LABEL=Ledger/Bills
GMAIL_ALLOWED_SENDERS=bill@example-bank.com,statement@example-card.com
# Generate with: openssl rand -base64 32
GMAIL_TOKEN_ENCRYPTION_KEY=
GMAIL_SYNC_LOOKBACK_DAYS=30
# Optional known ZIP passwords are tried before the bounded 000000-999999 search.
GMAIL_ZIP_PASSWORDS=
GMAIL_ZIP_TIMEOUT_SECONDS=20
# Cloud Scheduler and Vercel send this secret to the Gmail drain and renewal requests.
CRON_SECRET=

# Optional Git commit author for GitHub API commits.
LEDGER_GIT_AUTHOR_NAME=Ledger Bot
LEDGER_GIT_AUTHOR_EMAIL=ledger-bot@example.com

# Docker Compose ports. The frontend independently serves the SPA at
# http://localhost:8080. Caddy is the HTTPS edge proxy; start it with server
# and frontend for one same-origin application URL. The API port binds to
# localhost by default, while Caddy reaches it over the internal Compose network.
SERVER_BIND_ADDRESS=127.0.0.1
SERVER_PORT=3000
FRONTEND_PORT=8080
CADDY_HTTP_PORT=80
CADDY_HTTPS_PORT=443
CADDY_SITE_ADDRESS=:80
# Set CADDY_TLS_DIRECTIVE=tls internal to use Caddy's local CA for private
# domains. Reuse existing Caddy state with the three CADDY_*_VOLUME settings.
CADDY_TLS_DIRECTIVE=
CADDY_FRONTEND_UPSTREAM=frontend:80
CADDY_DATA_VOLUME=beancount-ledger-web_caddy_data
CADDY_CONFIG_VOLUME=beancount-ledger-web_caddy_config
CADDY_VOLUMES_EXTERNAL=false

# Local index worker only. LEDGER_HOST_PATH is mounted at /data/ledger inside
# the indexer container. Compose keeps the API service free of local ledger
# files and schedules the one-shot indexer explicitly.
LEDGER_HOST_PATH=/home/borui/beancount-ledger
LEDGER_MOUNT_MODE=ro
BEAN_CHECK_BIN=bean-check
