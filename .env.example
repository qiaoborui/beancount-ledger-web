# Beancount Ledger Web — Vercel API production configuration

# Ledger writes: use the GitHub API directly. Do not set LEDGER_GIT_REMOTE,
# LEDGER_GIT_WORKDIR, LEDGER_ROOT, or BEAN_CHECK_BIN on the Vercel API service.
LEDGER_STORAGE=github_api
LEDGER_GIT_BRANCH=main
LEDGER_GITHUB_OWNER=OWNER
LEDGER_GITHUB_REPO=private-ledger
LEDGER_GITHUB_TOKEN=
LEDGER_GITHUB_API_URL=

# Hosted reads and persistent runtime state.
RUNTIME_STORE=postgres
RUNTIME_FILE_STORE=postgres
# Supabase Postgres. Use the direct or session-pooler connection string for the
# read model/indexer; the indexer uses full Postgres protocol features.
DATABASE_URL=postgres://postgres.PROJECT_REF:PASSWORD@aws-0-REGION.pooler.supabase.com:5432/postgres?sslmode=require
LEDGER_READ_MODEL=postgres
LEDGER_READ_MODEL_STRICT=true
LEDGER_INDEX_SOURCE_KEY=personal-ledger#main

# Required secrets.
AUTH_SECRET=
APP_PASSWORD=

# Public browser URL for passkeys.
PUBLIC_ORIGIN=https://ledger.example.com
WEBAUTHN_RP_ID=ledger.example.com
# Optional: allow a separately hosted frontend to call this backend with cookies.
# Separate entries with spaces, commas, tabs, or newlines.
LEDGER_CORS_ORIGINS=https://ledger.example.com

# AI provider.
LEDGER_AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4.1-mini

# Web Push notifications.
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:you@example.com

# Optional Git commit author for GitHub API commits.
LEDGER_GIT_AUTHOR_NAME=Ledger Bot
LEDGER_GIT_AUTHOR_EMAIL=ledger-bot@example.com

# Local index worker only. Configure these on the worker that clones, validates,
# and indexes the private ledger into Postgres; do not set them on Vercel.
# Docker compose reads these from your local .env when running the optional
# ledger-indexer profile against the same Supabase DATABASE_URL.
# LEDGER_STORAGE=remote_git
# INDEXER_LEDGER_STORAGE=remote_git
# LEDGER_GIT_REMOTE=https://x-access-token:TOKEN@github.com/OWNER/private-ledger.git
# LEDGER_GIT_BRANCH=main
# LEDGER_GIT_WORKDIR=/tmp/beancount-ledger-web/ledger
# LEDGER_HOST_PATH=/home/borui/beancount-ledger
# LEDGER_MOUNT_MODE=rw
# BEAN_CHECK_BIN=bean-check
# LEDGER_INDEX_INTERVAL_SECONDS=300
