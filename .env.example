# Beancount Ledger Web configuration

# Required in production: private Beancount ledger repository path.
# Local development defaults to ./examples/minimal-ledger if omitted by the web app.
LEDGER_ROOT=./examples/minimal-ledger

# Runtime state directory for passkeys, notifications, web push subscriptions, locks.
RUNTIME_DIR=./.runtime

# Generate with: openssl rand -base64 32
AUTH_SECRET=

# Single-user login password. Use a long random password for public deployment.
APP_PASSWORD=

# AI parser provider: deepseek or openai.
LEDGER_AI_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_BASE_URL=https://api.deepseek.com
DEEPSEEK_MODEL=deepseek-chat

OPENAI_API_KEY=
OPENAI_BASE_URL=https://api.openai.com
OPENAI_MODEL=gpt-4.1-mini

# Web Push notifications. Generate with: npx web-push generate-vapid-keys
WEB_PUSH_VAPID_PUBLIC_KEY=
WEB_PUSH_VAPID_PRIVATE_KEY=
WEB_PUSH_SUBJECT=mailto:you@example.com

# Optional if bean-check is not on PATH.
BEAN_CHECK_BIN=

# Git scheduler for the private ledger repository.
LEDGER_GIT_SCHEDULER=false
LEDGER_GIT_PULL_INTERVAL_MINUTES=15
LEDGER_GIT_COMMIT_INTERVAL_MINUTES=60
