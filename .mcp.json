{
  "mcpServers": {
    "ledger": {
      "command": "node",
      "args": ["agent/ledger-mcp-server.mjs"],
      "env": {
        "LEDGER_AGENT_TOOL_BASE_URL": "${LEDGER_AGENT_TOOL_BASE_URL}",
        "LEDGER_AGENT_TOOL_TOKEN": "${LEDGER_AGENT_TOOL_TOKEN}"
      },
      "cwd": ".",
      "lifecycle": "lazy"
    }
  }
}
